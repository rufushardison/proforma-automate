{
  "template_name": "Single Tenant Model",
  "template_file": "Single Tenant Model.xlsm",

  "_notes": {
    "blue_hex": "0070C0 — used for column HEADERS, not input cells. Actual input cells are unlocked (unprotected) and identified by cell protection scan.",
    "costs_tab": "Costs sheet — columns D/E = cost inputs for each line item (F = formula total). DD Costs columns L/M = inputs; N = formula total. All optional; used mainly for build-to-suit or value-add deals.",
    "circular_ref": "Macro updates D21 (Interest Carry) and D22 (Lender Fees) on Deal Summary, plus H5/H8 on Financing sheet. Formula: loan = total_project_cost * ltc; lender_fee = loan * fee_rate; interest_carry = loan * financing_rate * months_of_construction / 12.",
    "rent_roll": "Years 1–20 in W5:W24. Only the years with a lease term are populated; rest stay null. X5 is the free-rent months for year 1 only.",
    "dev_fee_rate": "T23 (Developer Fee %) — 4% of total hard+soft costs including lender fees but excluding the dev fee itself.",
    "sheet_names": ["Deal Summary", "Costs", "Proforma", "IRR ", "Financing", "Tax Credits", "Dealpath Outputs", "Financing (3 Refi)"]
  },

  "circular_ref_cells": {
    "interest_carry_deal_summary": { "sheet": "Deal Summary", "cell": "D21" },
    "lender_fees_deal_summary":    { "sheet": "Deal Summary", "cell": "D22" },
    "interest_carry_financing":    { "sheet": "Financing",    "cell": "H5"  },
    "lender_fees_financing":       { "sheet": "Financing",    "cell": "H8"  }
  },


{
  "template_name": "Multi Tenant Model",
  "template_file": "Multi Tenant Model.xlsm",

  "_extraction_notes": "COST CATEGORY MATCHING RULES: Only assign a value to an existing Costs sheet category if the user's description closely and literally matches that category's label. Do NOT infer or generalize — if the user's words do not clearly correspond to the category label, use an additional_cost slot instead. Examples of strict matching: 'sitework' or 'site work' → costs_sitework; 'landscaping' → costs_landscaping; 'roof' or 'roofing' → costs_roof_replacement; 'structural repairs' or 'structural work' → costs_structural_repairs (do NOT use this for 'pillar install', 'column work', 'support beams', or anything that doesn't explicitly say 'structural'). When a cost item does not clearly match an existing category, assign it to the next available additional_cost slot: write the user's original description (title-cased) to the label field (additional_cost_1_label through _10_label) and the dollar amount to the value field (additional_cost_1 through _10). Fill slots in order — use slot 1 first, then 2, and so on up to 10. TI (TENANT IMPROVEMENT) RULES: TI must NEVER be placed in any Costs sheet category. If TI is stated as a per-square-foot amount, extract it only as ti_psf on the individual tenant in the rent roll — do not calculate or record a total TI dollar amount anywhere. If TI is stated as a single lump sum total dollar amount (not PSF), extract it as additional_cost_amount (Deal Summary T20) — do not put it in the rent roll or the Costs sheet.",

  "_notes": {
    "blue_hex": "0070C0 — column headers only, not input cells. Inputs identified by protection scan.",
    "circular_ref": "Macro updates D18 (Interest Carry) and D19 (Lender Fees) on Deal Summary, plus Financing H5/H8. Same formula as template_a: c32 = base_costs / (1 - (1+dev_fee_rate)*ltc*(fee_rate + rate*months/12)).",
    "rent_roll_approach": "Rent Roll sheet has up to 17 tenant rows (11-27). Each row = one tenant. Column B = lease term years. Monthly PSF values fill columns Q-AB (2026), AD-AO (2027), AQ-BB (2028), BD-BO (2029), BQ-CB (2030), CD-DB (2031). Columns DE-DK = annual rent $ totals per year (2026-2032). We write the same base_rent_psf to all monthly cells for that tenant and compute annual totals as sf * psf.",
    "differences_from_template_a": [
      "Rent roll is on dedicated 'Rent Roll' sheet, not Deal Summary",
      "Rent Roll col B = lease_term_years (new); all other columns shifted +1",
      "building_sf input at S9",
      "Additional expense inputs: taxes T23, insurance T24, CAM T25, expense_increase T26, property_mgmt_fee_rate T27",
      "vacancy_rate at T31",
      "sale_closing_costs_rate at T29, sale_cap_rate_goal at T30",
      "Circular ref cells at D18/D19 (vs D21/D22 in template_a)",
      "Leasing commission is a percentage (T19), not a lump sum",
      "LTC at T35, Lender Fee at T36, Total Interest Carry Period at T37, Construction Months at T38"
    ],
    "sheet_names": ["Deal Summary", "Costs", "Proforma", "Rent Roll", "IRR ", "Financing", "Tax Credits", "Dealpath Outputs", "Financing (3 Refi)"]
  },

  "circular_ref_cells": {
    "interest_carry_deal_summary": { "sheet": "Deal Summary", "cell": "D18" },
    "lender_fees_deal_summary":    { "sheet": "Deal Summary", "cell": "D19" }
  },

  "rent_roll": {
    "_note": "Describes the Rent Roll sheet row structure. excel_writer iterates over the tenants list extracted by Claude and writes one row per tenant starting at first_tenant_row.",
    "sheet": "Rent Roll",
    "first_tenant_row": 11,
    "last_tenant_row": 27,
    "columns": {
      "lease_term_years":   "B",
      "tax_reimbursement":  "C",
      "ins_reimbursement":  "D",
      "cam_reimbursement":  "E",
      "annual_pct_increase": "F",
      "tenant_name":        "G",
      "unit":               "H",
      "sq_ft":              "I",
      "base_rent_psf":      "K",
      "ti_psf":             "L"
    },
    "monthly_psf_columns": {
      "2026": { "start": "Q", "end": "AB" },
      "2027": { "start": "AD", "end": "AO" },
      "2028": { "start": "AQ", "end": "BB" },
      "2029": { "start": "BD", "end": "BO" },
      "2030": { "start": "BQ", "end": "CB" },
      "2031": { "start": "CD", "end": "DB" }
    },
    "annual_rent_columns": {
      "2026": "DE",
      "2027": "DF",
      "2028": "DG",
      "2029": "DH",
      "2030": "DI",
      "2031": "DJ",
      "2032": "DK"
    }
  },


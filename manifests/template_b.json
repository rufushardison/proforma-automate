{
  "template_name": "Multi Tenant Model",
  "template_file": "Multi Tenant Model.xlsm",

  "_notes": {
    "blue_hex": "0070C0 — column headers only, not input cells. Inputs identified by protection scan.",
    "circular_ref": "Macro updates D18 (Interest Carry) and D19 (Lender Fees) on Deal Summary, plus Financing H5/H8. Same formula as template_a: c32 = base_costs / (1 - (1+dev_fee_rate)*ltc*(fee_rate + rate*months/12)).",
    "rent_roll_approach": "Rent Roll sheet has up to 17 tenant rows (11-27). Each row = one tenant. Monthly PSF values fill columns P-DA (84 cells per row, 7 years × 12 months). Columns DD-DJ = annual rent $ totals per year (2026-2032). We write the same base_rent_psf to all monthly cells for that tenant and compute DD-DJ as sf * psf.",
    "differences_from_template_a": [
      "Rent roll is on dedicated 'Rent Roll' sheet, not Deal Summary",
      "building_sf input at S9 (new field)",
      "Additional expense inputs: taxes T23, insurance T24, CAM T25, expense_increase T26, property_mgmt_fee_rate T27",
      "vacancy_rate at T31 (new field)",
      "sale_closing_costs_rate at T29 (was T27 in template_a)",
      "sale_cap_rate_goal at T30 (was T28 in template_a)",
      "Circular ref cells at D18/D19 (vs D21/D22 in template_a)",
      "Leasing commission is single flat-fee line: label S19 [editable], value T19"
    ],
    "sheet_names": ["Deal Summary", "Costs", "Proforma", "Rent Roll", "IRR ", "Financing", "Tax Credits", "Dealpath Outputs", "Financing (3 Refi)"]
  },

  "circular_ref_cells": {
    "interest_carry_deal_summary": { "sheet": "Deal Summary", "cell": "D18" },
    "lender_fees_deal_summary":    { "sheet": "Deal Summary", "cell": "D19" },
    "interest_carry_financing":    { "sheet": "Financing",    "cell": "H5"  },
    "lender_fees_financing":       { "sheet": "Financing",    "cell": "H8"  }
  },

  "rent_roll": {
    "_note": "Describes the Rent Roll sheet row structure. excel_writer iterates over the tenants list extracted by Claude and writes one row per tenant starting at first_tenant_row.",
    "sheet": "Rent Roll",
    "first_tenant_row": 11,
    "last_tenant_row": 27,
    "columns": {
      "tax_reimbursement":  "B",
      "ins_reimbursement":  "C",
      "cam_reimbursement":  "D",
      "annual_pct_increase": "E",
      "tenant_name":        "F",
      "unit":               "G",
      "sq_ft":              "H",
      "base_rent_psf":      "J",
      "ti_psf":             "K"
    },
    "monthly_psf_columns": {
      "2026": { "start": "P", "end": "AA" },
      "2027": { "start": "AC", "end": "AN" },
      "2028": { "start": "AP", "end": "BA" },
      "2029": { "start": "BC", "end": "BN" },
      "2030": { "start": "BP", "end": "CA" },
      "2031": { "start": "CC", "end": "DA" }
    },
    "annual_rent_columns": {
      "2026": "DD",
      "2027": "DE",
      "2028": "DF",
      "2029": "DG",
      "2030": "DH",
      "2031": "DI",
      "2032": "DJ"
    }
  },

  "assumptions": {

    "property_name": {
      "sheet": "Deal Summary", "cell": "S6",
      "type": "string", "required": false,
      "label": "Property Name",
      "sample_value": "Knox Abbot 3 Tenant Bldg"
    },

